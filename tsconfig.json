{
  "include": [
    "src/**/*.ts", 
    "src/**/*.tsx", 
    "vite.config.ts", 
    "eslint.config.js",
    ".tanstack/**/*.ts"  
  ],
  "exclude": [
    "node_modules", 
    ".output", 
    "dist"                   /* Exclude production build targets */
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    
    /* Path Mapping */
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}